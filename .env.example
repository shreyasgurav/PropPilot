# ---------------------------------------------------------------------------
# BrokerPulse environment variables
# Copy this file to .env and fill in real values.
# ---------------------------------------------------------------------------

# PostgreSQL (Supabase). DATABASE_URL uses the pooled connection (port 6543),
# DIRECT_URL uses the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Meta WhatsApp Business API (Cloud API)
# Create an app at https://developers.facebook.com -> add the WhatsApp product.
# META_APP_ID / META_APP_SECRET: App Dashboard -> Settings -> Basic.
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
# WHATSAPP_ACCESS_TOKEN: a PERMANENT System User token from Meta Business
# Manager (Business Settings -> System Users -> Generate token, with
# whatsapp_business_messaging + whatsapp_business_management scopes).
WHATSAPP_ACCESS_TOKEN="your-permanent-system-user-token"
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: any random string you choose; paste the SAME
# value into Meta -> WhatsApp -> Configuration -> Webhook "Verify token".
WHATSAPP_WEBHOOK_VERIFY_TOKEN="generate-a-long-random-string"
# Graph API version to target.
META_API_VERSION="v19.0"

# Per-broker WhatsApp identifiers (Phone Number ID + WABA ID) are NOT env vars.
# Each broker connects their own number in Settings; the values are stored on
# the Broker row (metaPhoneNumberId / metaWabaId).

# Postmark inbound email parsing
POSTMARK_WEBHOOK_TOKEN="your-postmark-inbound-webhook-token"

# Secret shared between Vercel Cron and /api/jobs/process
CRON_SECRET="generate-a-long-random-string"

# Public base URL of the app (used for building links in messages)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
