# ---------------------------------------------------------------------------
# BrokerPulse environment variables
# Copy this file to .env and fill in real values.
# ---------------------------------------------------------------------------

# PostgreSQL (Supabase). DATABASE_URL uses the pooled connection (port 6543),
# DIRECT_URL uses the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# WATI (WhatsApp) - https://app.wati.io -> API Docs
WATI_API_ENDPOINT="https://live-mt-server.wati.io/xxxxx"
WATI_API_TOKEN="Bearer xxxxx"

# Postmark inbound email parsing
POSTMARK_WEBHOOK_TOKEN="your-postmark-inbound-webhook-token"

# Secret shared between Vercel Cron and /api/jobs/process
CRON_SECRET="generate-a-long-random-string"

# Public base URL of the app (used for building links in messages)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
